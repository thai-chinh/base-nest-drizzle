# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# Snowflake ID — unique per server instance (0-1023)
# Nếu chạy nhiều instance, mỗi instance phải có giá trị khác nhau
SNOWFLAKE_MACHINE_ID=1

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB=wedtech_db
# Hoặc dùng connection string trực tiếp (ưu tiên hơn nếu có)
# DATABASE_URL=postgresql://admin:admin123@localhost:5432/wedtech_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Dùng chuỗi ngẫu nhiên đủ dài, ví dụ: openssl rand -base64 64
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
JWT_REFRESH_SECRET=change_me_to_a_different_random_secret_at_least_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Storage (MinIO) ──────────────────────────────────────────────────────────
STORAGE_PROVIDER=minio

MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY_ID=minioadmin
MINIO_SECRET_ACCESS_KEY=minioadmin
MINIO_BUCKET=wedtech
MINIO_REGION=us-east-1
# URL public để truy cập file (dùng cho dev local)
MINIO_PUBLIC_URL=http://localhost:9000

# Credentials đăng nhập MinIO Console (http://localhost:9001)
MINIO_USER=minioadmin
MINIO_PASS=minioadmin

# ─── Storage (AWS S3) — bỏ comment nếu dùng S3 thay MinIO ───────────────────
# STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key
# AWS_REGION=ap-southeast-1
# AWS_S3_BUCKET=wedtech

# ─── Storage (Cloudflare R2) — bỏ comment nếu dùng R2 ───────────────────────
# STORAGE_PROVIDER=r2
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your_r2_access_key_id
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# CLOUDFLARE_R2_BUCKET=wedtech
# CLOUDFLARE_R2_PUBLIC_URL=https://storage.yourdomain.com
