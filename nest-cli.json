{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "assets": [
      { "include": "**/*.onnx", "outDir": "dist", "watchAssets": true }
    ],
    "deleteOutDir": true,
    "webpack": false,
    "tsConfigPath": "tsconfig.build.json",
    "builder": {
      "type": "swc",
      "options": {
        "swcrcPath": ".swcrc"
      }
    }
  },
  "watchOptions": {
    "ignored": [
      "**/node_modules/**",
      "**/dist/**",
      "**/.git/**",
      "**/src/**",
      "**/*.spec.ts"
    ]
  }
}
