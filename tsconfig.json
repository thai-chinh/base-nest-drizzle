{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@/*": ["src/*"],
      "@/common": ["src/common"],
      "@/common/*": ["src/common/*"],
      "@/config": ["src/config"],
      "@/config/*": ["src/config/*"],
      "@/core": ["src/core"],
      "@/core/*": ["src/core/*"],
      "@/modules": ["src/modules"],
      "@/modules/*": ["src/modules/*"]
    }
  }
}
